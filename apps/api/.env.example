# ────────────────────────────────────────────────────────────────────────────
# Vilar DS — API environment variables
# Copier ce fichier en .env et remplir les valeurs
# ────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Base de données PostgreSQL (obligatoire)
DATABASE_URL=postgresql://vilar:vilar_secret@localhost:5432/vilar_ds

# Redis (obligatoire pour les jobs BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=       # décommenter si Redis a un mot de passe

# JWT — générer avec : openssl rand -hex 64 (obligatoire)
JWT_ACCESS_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_hex_64_different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (optionnel — désactive le billing si absent)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# OAuth Google (optionnel — désactive le login Google si absent)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Email SMTP (optionnel — les emails sont loggués en console si absent)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vilar-ds.fr

# Sentry (optionnel)
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
