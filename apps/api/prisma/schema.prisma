// ══════════════════════════════════════════════════════════════════════════════
// Vilar DS — Prisma Schema
// PostgreSQL · Multi-tenant (tenant_id row-level isolation)
// ══════════════════════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN   // Vilar DS platform admin
  TENANT_ADMIN  // Company admin
  MANAGER
  EMPLOYEE
  ACCOUNTANT
  READONLY
}

enum TenantPlan {
  FREE
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum InvoiceType {
  QUOTE    // Devis
  INVOICE  // Facture
  CREDIT   // Avoir
}

enum PaymentMethod {
  BANK_TRANSFER
  CHECK
  CASH
  CARD
  STRIPE
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  TRIAL_PERIOD
}

enum EmployeeType {
  EMPLOYEE
  SUBCONTRACTOR
  INTERN
  FREELANCE
}

enum InteractionType {
  EMAIL
  PHONE
  MEETING
  NOTE
  QUOTE_SENT
  INVOICE_SENT
  COMPLAINT
  FOLLOW_UP
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  INACTIVE
  BLOCKED
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  STRIPE_EVENT
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT (Company / Organisation)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id            String       @id @default(uuid())
  slug          String       @unique // used in subdomain: acme.vilar-ds.fr
  name          String
  siren         String?      @unique
  vatNumber     String?
  plan          TenantPlan   @default(FREE)
  status        TenantStatus @default(TRIAL)
  trialEndsAt   DateTime?

  // Billing
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  currentPeriodEnd     DateTime?

  // Settings
  logoUrl          String?
  primaryColor     String?  @default("#1a56db")
  defaultCurrency  String   @default("EUR")
  defaultTaxRate   Float    @default(20.0)
  invoicePrefix    String   @default("FAC")
  quotePrefix      String   @default("DEV")
  nextInvoiceSeq   Int      @default(1)
  nextQuoteSeq     Int      @default(1)
  timezone         String   @default("Europe/Paris")
  locale           String   @default("fr-FR")

  // Address
  address          String?
  city             String?
  postalCode       String?
  country          String   @default("FR")

  // Contact
  email            String?
  phone            String?
  website          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users         User[]
  contacts      Contact[]
  invoices      Invoice[]
  employees     Employee[]
  auditLogs     AuditLog[]
  usageRecords  UsageRecord[]
  webhookEvents WebhookEvent[]

  @@index([slug])
  @@index([stripeCustomerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String?
  firstName    String
  lastName     String
  avatarUrl    String?
  phone        String?
  role         UserRole @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  emailVerified Boolean @default(false)

  // OAuth
  googleId     String? @unique
  googleToken  String?

  // 2FA (future)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Password reset
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?

  // Refresh tokens stored in Redis — only last N kept
  lastLoginAt  DateTime?
  lastLoginIp  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions  UserPermission[]
  auditLogs    AuditLog[]
  createdInvoices  Invoice[]      @relation("InvoiceCreatedBy")
  createdContacts  Contact[]      @relation("ContactCreatedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

// Fine-grained permissions (beyond role)
model UserPermission {
  id         String  @id @default(uuid())
  userId     String
  resource   String  // e.g. "invoices", "hr", "crm"
  action     String  // e.g. "read", "write", "delete"
  granted    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource, action])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — CONTACTS / CLIENTS
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id          String        @id @default(uuid())
  tenantId    String
  createdById String

  // Identity
  isCompany   Boolean       @default(false)
  companyName String?
  firstName   String?
  lastName    String?
  email       String?
  phone       String?
  mobile      String?
  website     String?
  status      ContactStatus @default(LEAD)

  // Address
  address     String?
  city        String?
  postalCode  String?
  country     String  @default("FR")

  // Business
  siren       String?
  vatNumber   String?
  notes       String?
  tags        String[] @default([])
  source      String?  // "referral", "website", "cold-call"

  // Stats (denormalized for perf)
  totalRevenue     Float @default(0)
  totalInvoices    Int   @default(0)
  lastInteraction  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User    @relation("ContactCreatedBy", fields: [createdById], references: [id])
  interactions Interaction[]
  invoices     Invoice[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, email])
}

model Interaction {
  id          String          @id @default(uuid())
  contactId   String
  type        InteractionType
  subject     String?
  content     String
  occurredAt  DateTime        @default(now())
  createdById String?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([contactId, occurredAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICING — INVOICES / QUOTES
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id           String        @id @default(uuid())
  tenantId     String
  contactId    String?
  createdById  String

  type         InvoiceType   @default(INVOICE)
  status       InvoiceStatus @default(DRAFT)
  number       String        // FAC-2024-0001 (unique per tenant)

  // Dates
  issuedAt     DateTime      @default(now())
  dueAt        DateTime?
  paidAt       DateTime?
  sentAt       DateTime?

  // Amounts (stored in cents for precision)
  subtotalCents    Int       @default(0)
  discountCents    Int       @default(0)
  taxCents         Int       @default(0)
  totalCents       Int       @default(0)
  paidCents        Int       @default(0)

  taxRate          Float     @default(20.0)
  currency         String    @default("EUR")

  // Content
  notes            String?
  termsConditions  String?
  footer           String?

  // Stripe payment
  stripePaymentIntentId String?
  stripePaymentUrl      String?

  // PDF storage
  pdfUrl           String?
  pdfGeneratedAt   DateTime?

  // Linked quote (when invoice created from quote)
  originQuoteId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact?  @relation(fields: [contactId], references: [id])
  createdBy User      @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lineItems InvoiceLineItem[]
  payments  InvoicePayment[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([contactId])
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  position    Int
  description String
  quantity    Float   @default(1)
  unitPriceCents Int
  taxRate     Float   @default(20.0)
  discountPct Float   @default(0)
  totalCents  Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoicePayment {
  id            String        @id @default(uuid())
  invoiceId     String
  amountCents   Int
  method        PaymentMethod
  reference     String?
  paidAt        DateTime      @default(now())
  notes         String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// HR — EMPLOYEES
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id           String         @id @default(uuid())
  tenantId     String
  userId       String?        // linked app user if any

  // Identity
  firstName    String
  lastName     String
  email        String
  phone        String?
  mobile       String?
  avatarUrl    String?

  // Professional
  type         EmployeeType   @default(EMPLOYEE)
  status       EmployeeStatus @default(ACTIVE)
  position     String?
  department   String?
  hiredAt      DateTime?
  terminatedAt DateTime?

  // Compensation
  grossSalary      Float?
  salaryPeriod     String?  @default("monthly") // monthly, hourly
  hourlyRate       Float?

  // Subcontractor specifics
  companyName  String?
  siren        String?
  vatNumber    String?

  // Contract
  contractType     String?  // CDI, CDD, freelance
  contractEndDate  DateTime?

  // Address
  address      String?
  city         String?
  postalCode   String?
  country      String  @default("FR")

  notes        String?
  tags         String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaves   EmployeeLeave[]
  timesheets EmployeeTimesheet[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
}

model EmployeeLeave {
  id           String    @id @default(uuid())
  employeeId   String
  type         String    // congés, maladie, RTT, formation
  startDate    DateTime
  endDate      DateTime
  days         Float
  approved     Boolean   @default(false)
  approvedById String?
  notes        String?
  createdAt    DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeTimesheet {
  id          String   @id @default(uuid())
  employeeId  String
  date        DateTime @db.Date
  hoursWorked Float
  description String?
  projectRef  String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING — USAGE & QUOTAS
// ─────────────────────────────────────────────────────────────────────────────

model UsageRecord {
  id        String   @id @default(uuid())
  tenantId  String
  metric    String   // "invoices_created", "users_count", "storage_mb"
  value     Int
  period    String   // "2024-01" (monthly bucket)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metric, period])
  @@index([tenantId])
}

// Stripe webhook events (idempotent processing)
model WebhookEvent {
  id          String    @id // Stripe event ID
  tenantId    String?
  type        String
  data        Json
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([type])
  @@index([processed])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String
  userId     String?
  action     AuditAction
  resource   String      // "invoice", "contact", "employee"
  resourceId String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, resource])
  @@index([tenantId, createdAt])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BACKGROUND JOBS TRACKING
// ─────────────────────────────────────────────────────────────────────────────

model JobRecord {
  id        String    @id @default(uuid())
  tenantId  String?
  queue     String
  jobId     String    @unique
  type      String
  status    JobStatus @default(PENDING)
  payload   Json?
  result    Json?
  error     String?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([queue])
}
