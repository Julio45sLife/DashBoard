{
  "name": "vilar-ds-saas",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "yarn workspace @vilar-ds/api dev",
    "dev:web": "yarn workspace @vilar-ds/web dev",
    "dev": "concurrently \"yarn dev:api\" \"yarn dev:web\"",
    "build:api": "yarn workspace @vilar-ds/api build",
    "build:web": "yarn workspace @vilar-ds/web build",
    "test:api": "yarn workspace @vilar-ds/api test",
    "test:web": "yarn workspace @vilar-ds/web test",
    "db:migrate": "yarn workspace @vilar-ds/api prisma migrate deploy",
    "db:seed": "yarn workspace @vilar-ds/api prisma db seed",
    "lint": "eslint apps --ext .ts,.tsx --max-warnings 0"
  },
  "devDependencies": {
    "@types/passport-google-oauth20": "^2.0.17",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0"
  },
  "dependencies": {
    "@types/minimatch": "^6.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
